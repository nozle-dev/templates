{
  "name": "nozle-templates",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Next.js templates for every Nozle billing model",
  "scripts": {
    "dev:flat": "pnpm --filter flat-subscription dev",
    "dev:saas": "pnpm --filter saas-usage dev",
    "dev:compute": "pnpm --filter compute dev",
    "dev:credits": "pnpm --filter credit-based dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
