{
  "name": "create-nozle-app",
  "version": "0.3.0",
  "description": "Create a Next.js SaaS app with Nozle billing - choose from 4 production-ready templates",
  "type": "module",
  "bin": {
    "create-nozle-app": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:cli": "tsup",
    "dev:cli": "tsup --watch",
    "typecheck:cli": "tsc --noEmit",
    "prepublishOnly": "pnpm build:cli",
    "dev:flat": "pnpm --filter flat-subscription dev",
    "dev:saas": "pnpm --filter saas-usage dev",
    "dev:compute": "pnpm --filter compute dev",
    "dev:credits": "pnpm --filter credit-based dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "keywords": [
    "nozle",
    "nextjs",
    "billing",
    "usage-based",
    "saas-template",
    "boilerplate",
    "create-app",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@nozle-js/node": "^0.3.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "figlet": "^1.11.0",
    "fs-extra": "^11.2.0",
    "gradient-string": "^3.0.0",
    "nanospinner": "^1.2.2",
    "ora": "^8.1.1",
    "prompts": "^2.4.2",
    "validate-npm-package-name": "^5.0.1"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.5",
    "@types/prompts": "^2.4.9",
    "@types/validate-npm-package-name": "^4.0.2",
    "tsup": "^8.4.0",
    "turbo": "^2.3.3",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
