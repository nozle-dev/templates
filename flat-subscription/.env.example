# =============================================================================
# NOZLE TEMPLATES - CONFIGURATION
# =============================================================================
# Quick start: Copy this to .env.local and you're ready to go!
#
# FOR PRODUCTION: Connect your database and replace demo credentials with real auth
# =============================================================================

# -----------------------------------------------------------------------------
# DEMO MODE (ENABLED BY DEFAULT)
# -----------------------------------------------------------------------------
DEMO_MODE=true

# Demo Login Credentials
DEMO_USER_EMAIL=demo@nozle.app
DEMO_USER_PASSWORD=user@123
DEMO_USER_NAME=Demo User

# -----------------------------------------------------------------------------
# NOZLE SDK API KEY (OPTIONAL FOR DEMO)
# -----------------------------------------------------------------------------
# Get your key from: https://nozle.ai/dashboard/api-keys
# The public key is auto-derived from this (sk_ → pk_) in next.config.ts
NOZLE_API_KEY=sk_test_demo

# -----------------------------------------------------------------------------
# STRIPE (OPTIONAL)
# -----------------------------------------------------------------------------
# For testing checkout flows
# Get keys from: https://dashboard.stripe.com/test/apikeys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
# STRIPE_SECRET_KEY=sk_test_your_key_here

# -----------------------------------------------------------------------------
# PRODUCTION: DATABASE & AUTH
# -----------------------------------------------------------------------------
# Uncomment and configure for production use
# DATABASE_URL=postgresql://user:password@localhost:5432/your_db
# SESSION_SECRET=generate-a-random-32-char-secret-key
