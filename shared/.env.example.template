# =============================================================================
# NOZLE TEMPLATES - DEMO MODE CONFIGURATION
# =============================================================================
#
# This template demonstrates Nozle SDK integration without requiring a database.
# All data shown is mocked for educational purposes.
#
# FOR PRODUCTION USE:
# - Uncomment and fill in database credentials
# - Set up real authentication (not demo user/pass)
# - Connect to your Nozle account with real API keys
# - Implement actual data persistence
# =============================================================================

# -----------------------------------------------------------------------------
# DEMO CREDENTIALS (FOR HOSTED DEMO / DEVELOPMENT)
# -----------------------------------------------------------------------------
# These are used for the login screen in demo mode
# In production: Replace with real authentication (OAuth, Auth0, Clerk, etc.)

NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEMO_USER_EMAIL=demo@example.com
NEXT_PUBLIC_DEMO_USER_PASSWORD=demo123
DEMO_USER_ID=demo_user_123
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_NAME=Demo User

# -----------------------------------------------------------------------------
# NOZLE SDK (REQUIRED)
# -----------------------------------------------------------------------------
# Get your API keys from: https://nozle.ai/dashboard/api-keys
# Public key is safe to expose in client-side code

NEXT_PUBLIC_NOZLE_API_KEY=pk_test_your_key_here
NOZLE_API_KEY=sk_test_your_secret_key_here
NOZLE_CUSTOMER_ID=cus_your_customer_id
NOZLE_WORKSPACE_ID=ws_your_workspace_id

# Optional: For local development against Nozle API
# NOZLE_API_URL=http://localhost:8080
# NOZLE_EVENTS_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# STRIPE (OPTIONAL - FOR CHECKOUT FLOW)
# -----------------------------------------------------------------------------
# Required if you want to test the billing checkout flow
# Get test keys from: https://dashboard.stripe.com/test/apikeys

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret

# -----------------------------------------------------------------------------
# DATABASE (COMMENTED - NOT USED IN DEMO)
# -----------------------------------------------------------------------------
# In production, uncomment and configure your database
# This template uses PostgreSQL examples, but you can use any database
#
# DATABASE_URL=postgresql://user:password@localhost:5432/your_db_name
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=your_database_name
# DB_USER=your_database_user
# DB_PASSWORD=your_database_password
#
# EXAMPLE QUERIES TO IMPLEMENT:
# - Store user accounts: CREATE TABLE users (id, email, hashed_password, created_at)
# - Store projects: CREATE TABLE projects (id, user_id, name, status, created_at)
# - Store API keys: CREATE TABLE api_keys (id, user_id, key_hash, name, created_at)
# - Store usage logs: CREATE TABLE usage_logs (id, user_id, endpoint, tokens, timestamp)

# -----------------------------------------------------------------------------
# AUTHENTICATION (COMMENTED - NOT USED IN DEMO)
# -----------------------------------------------------------------------------
# In production, use a real auth provider instead of demo credentials
#
# Option 1: NextAuth.js
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-key-here
#
# Option 2: Clerk
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
#
# Option 3: Auth0
# AUTH0_DOMAIN=your-domain.auth0.com
# AUTH0_CLIENT_ID=your_client_id
# AUTH0_CLIENT_SECRET=your_client_secret

# -----------------------------------------------------------------------------
# SESSION (COMMENTED - NOT USED IN DEMO)
# -----------------------------------------------------------------------------
# For production session management with iron-session or similar
# SESSION_SECRET=your-random-32-char-secret-key-here
# SESSION_MAX_AGE=2592000  # 30 days in seconds

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# TEMPLATE-SPECIFIC SETTINGS
# -----------------------------------------------------------------------------

# For saas-usage template: Rate limiting (example)
# RATE_LIMIT_MAX_REQUESTS=1000
# RATE_LIMIT_WINDOW_MS=60000

# For compute template: Default instance config (example)
# DEFAULT_INSTANCE_TYPE=small
# MAX_INSTANCES_PER_USER=10

# For credit-based template: Default credit amounts (example)
# DEFAULT_CREDIT_BALANCE=1000
# CREDIT_PURCHASE_AMOUNTS=500,1000,5000
