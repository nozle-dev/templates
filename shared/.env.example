# Nozle Configuration
NOZLE_API_KEY=sk_live_your_api_key_here
NOZLE_CUSTOMER_ID=customer_demo
NOZLE_WORKSPACE_ID=workspace_your_id_here

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here

# Demo Mode (set to false to use real database)
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Demo User Credentials (ONLY used when DEMO_MODE=true)
# Pre-filled in login form - just click "Sign in"
DEMO_USER_EMAIL=demo@nozle.dev
DEMO_USER_PASSWORD=demo1234
DEMO_USER_NAME=Demo User
NEXT_PUBLIC_DEMO_USER_EMAIL=demo@nozle.dev
NEXT_PUBLIC_DEMO_USER_PASSWORD=demo1234

# Session Secret (change in production!)
SESSION_SECRET=complex_password_at_least_32_characters_long_change_this_in_production

# Database (required when DEMO_MODE=false)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Optional: Local development
# NOZLE_API_URL=http://localhost:8080
# NOZLE_EVENTS_URL=http://localhost:3000

# App URL (for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
